class Solution {
    public int[] dailyTemperatures(int[] temperatures) {
        int n=temperatures.length;
      int []ans= new int[n];
      Stack <Integer> stack =new Stack<>();
      for(int i=0;i<n;i++){
        while(!stack.empty() && temperatures[stack.peek()]<temperatures[i]){
            Integer pop = stack.pop();
            ans[pop]=i-pop;
        }
        stack.push(i);
      }
      return ans;
    }
}