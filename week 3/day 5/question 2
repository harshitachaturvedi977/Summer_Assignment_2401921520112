class RecentCounter {
     int [] ans=new int[10000];
     int start,end;
    public RecentCounter() {
        start=0;
        end=0;
    }
    
    public int ping(int t) {
       while (start < end && (t - ans[start] > 3000)) { 
            start++; 
       }
       ans[end++] = t; 
        return end - start;  
    }
}