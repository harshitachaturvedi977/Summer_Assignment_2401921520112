class Solution {
    public double findMaxAverage(int[] nums, int k) {
      int sum=0;
      for(int i=0;i<k;i++){
        sum+=nums[i];
      }
      int maxsum=sum;
      int i=0,j=k;
      while(j<nums.length){
        sum-=nums[i];
        i++;
        sum+=nums[j];
        j++;
        maxsum=Math.max(maxsum,sum);
      }
      return (double)maxsum/k;
    }
}