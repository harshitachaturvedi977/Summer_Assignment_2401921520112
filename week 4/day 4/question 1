class Solution {
    public boolean hasPathSum(TreeNode root, int targetSum) {
        if (root == null) return false;
        if (root.left == null && root.right == null) {
            boolean i= targetSum - root.val == 0;
            return i;
        }
        targetSum -= root.val;
        boolean k=hasPathSum(root.left, targetSum) || hasPathSum(root.right, targetSum); 
        return k;  
    }
}