class Solution {
    public int diameterOfBinaryTree(TreeNode root) {
         height(root);
        return ans;
    }
    int ans = 0;
    public int height(TreeNode root) {
        if (root == null) return 0;
        int l = height(root.left);
        int r = height(root.right);
        ans = Math.max(ans, l + r);
        return 1 + Math.max(l, r);
    }
}